
# Which port uvicorn binds to
MODEL_SERVER_PORT=8001

# Human-readable label for this instance — will matter once we run
# stable and canary as two instances of this same service (later step)
MODEL_VERSION_LABEL=stable

# Path to the local model file this instance loads at startup.
# Will be replaced/supplemented by an MLflow registry URI in a later step.
MODEL_PATH=./artifacts/model.joblib