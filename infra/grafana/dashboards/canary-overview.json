{
  "title": "Canary ML Platform Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "title": "Canary Traffic Weight (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{ "expr": "gateway_canary_weight_percent" }]
    },
    {
      "title": "Request Rate by Target",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{ "expr": "rate(gateway_requests_total[1m])", "legendFormat": "{{target}}" }]
    },
    {
      "title": "p99 Latency by Model Version",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(model_server_prediction_latency_ms_bucket[1m]))",
          "legendFormat": "{{model_version_label}}"
        }
      ]
    },
    {
      "title": "Error Rate by Model Version",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(model_server_predictions_total{status=\"error\"}[1m]) / rate(model_server_predictions_total[1m])",
          "legendFormat": "{{model_version_label}}"
        }
      ]
    }
  ]
}